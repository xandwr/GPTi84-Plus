# Copy to .env (gitignored) and fill in. Loaded by `just relay-llm`
# locally and shipped to nimble:/home/agent/ti84-superdeluxe/.env by
# `just deploy-relay-llm`.

# Cloudflare Access service-token credentials. The Pico presents these
# as CF-Access-Client-Id / CF-Access-Client-Secret headers when opening
# the WSS to relay.xandwr.com. Rotate via the Access dashboard.
CF_ACCESS_CLIENT_ID=....access
CF_ACCESS_CLIENT_SECRET=...

# Ollama API key. Default target is Ollama Cloud (https://ollama.com/api/chat,
# model gpt-oss:120b-cloud). For a local Ollama instance, leave this
# empty and override OLLAMA_URL/OLLAMA_MODEL in the environment.
OLLAMA_API_KEY=...

# Optional overrides. Defaults are wired into tools/relay_server.py.
# OLLAMA_URL=https://ollama.com/api/chat
# OLLAMA_MODEL=gpt-oss:120b-cloud
