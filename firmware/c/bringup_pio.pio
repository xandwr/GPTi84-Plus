; PIO programs for bring-up tests, mirroring src/test_pico_data_works.py.
; pioasm auto-generates `<program>_program_get_default_config(offset)` for
; each program -- no extra C helpers needed here.

.program hold_high
    set pins, 1
.wrap_target
    nop
.wrap


.program shift_out
.wrap_target
    out pins, 1 [1]
.wrap
