{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "pico-w",
      "displayName": "Pico W (arm-none-eabi-gcc)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "toolchainFile": "/usr/share/pico-sdk/cmake/preload/toolchains/pico_arm_cortex_m0plus_gcc.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "PICO_BOARD": "pico_w"
      }
    }
  ],
  "buildPresets": [
    { "name": "pico-w", "configurePreset": "pico-w" }
  ]
}
