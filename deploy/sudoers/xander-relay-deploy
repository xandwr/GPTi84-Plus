# Allow xander to run the relay-llm deploy commands without a password.
# Used by `just deploy-relay-llm` from the ti84-superdeluxe repo.
#
# Install on nimble (one time):
#   ssh nimble
#   sudo visudo -f /etc/sudoers.d/xander-relay-deploy
#   <paste this file's contents below the comment block, save>
#   sudo chmod 440 /etc/sudoers.d/xander-relay-deploy
#
# visudo validates syntax on save. Do NOT use `cat >` or a regular
# editor: a syntax error in sudoers.d/ breaks sudo machine-wide until
# rescued via pkexec or boot media.
#
# Argument matching is EXACT. If the deploy recipe changes (new flag,
# different path), mirror it here or sudo will re-prompt.
#
# Verify paths on the target box first:
#   which install systemctl
# Arch typically resolves both to /usr/bin/. Adjust if your box differs.

xander ALL=(root) NOPASSWD: /usr/bin/install -m 644 /tmp/relay-llm.service /etc/systemd/system/relay-llm.service
xander ALL=(root) NOPASSWD: /usr/bin/systemctl daemon-reload
xander ALL=(root) NOPASSWD: /usr/bin/systemctl is-active --quiet relay
xander ALL=(root) NOPASSWD: /usr/bin/systemctl disable --now relay
xander ALL=(root) NOPASSWD: /usr/bin/systemctl reset-failed relay-llm
xander ALL=(root) NOPASSWD: /usr/bin/systemctl enable --now relay-llm
xander ALL=(root) NOPASSWD: /usr/bin/systemctl status --no-pager relay-llm
xander ALL=(root) NOPASSWD: /usr/bin/systemctl restart relay-llm
xander ALL=(root) NOPASSWD: /usr/bin/systemctl stop relay-llm
xander ALL=(root) NOPASSWD: /usr/bin/systemctl start relay-llm
xander ALL=(root) NOPASSWD: /usr/bin/systemctl start wsbridge
xander ALL=(root) NOPASSWD: /usr/bin/systemctl status --no-pager wsbridge
