{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "TI-84 Plus BASIC",
  "scopeName": "source.ti84p",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#label" },
    { "include": "#keyword-control" },
    { "include": "#keyword-io" },
    { "include": "#keyword-graphics" },
    { "include": "#keyword-math" },
    { "include": "#keyword-memory" },
    { "include": "#operator" },
    { "include": "#builtin-list" },
    { "include": "#builtin-matrix" },
    { "include": "#builtin-string" },
    { "include": "#number" },
    { "include": "#variable" }
  ],
  "repository": {
    "comment": {
      "comment": "Bare string on its own line used as a comment (TI-BASIC idiom)",
      "name": "comment.line.ti84p",
      "match": "^\\s*\"[^\"]*\"\\s*$"
    },
    "string": {
      "name": "string.quoted.double.ti84p",
      "begin": "\"",
      "end": "\"|((?=->)|$)",
      "patterns": []
    },
    "label": {
      "patterns": [
        {
          "name": "entity.name.label.ti84p",
          "match": "\\b(Lbl)\\s+([A-Z][A-Z0-9]{0,1})\\b",
          "captures": {
            "1": { "name": "keyword.control.ti84p" },
            "2": { "name": "entity.name.label.ti84p" }
          }
        },
        {
          "name": "keyword.control.ti84p",
          "match": "\\b(Goto)\\s+([A-Z][A-Z0-9]{0,1})\\b",
          "captures": {
            "1": { "name": "keyword.control.ti84p" },
            "2": { "name": "variable.other.label-ref.ti84p" }
          }
        }
      ]
    },
    "keyword-control": {
      "name": "keyword.control.ti84p",
      "match": "\\b(If|Then|Else|End|For|While|Repeat|Return|Stop|IS>|DS<|Menu|prgm|Pause)\\b"
    },
    "keyword-io": {
      "name": "keyword.other.io.ti84p",
      "match": "\\b(Disp|Input|Prompt|Output|ClrHome|getKey|DispGraph|DispTable)\\b"
    },
    "keyword-graphics": {
      "name": "keyword.other.graphics.ti84p",
      "match": "\\b(ClrDraw|DrawF|DrawInv|Line|Circle|Pt-On|Pt-Off|Pt-Change|Pxl-On|Pxl-Off|Pxl-Change|pxl-Test|Text|Shade|Tangent|Horizontal|Vertical|StorePic|RecallPic|StoreGDB|RecallGDB|AxesOn|AxesOff|GridOn|GridOff|LabelOn|LabelOff|CoordOn|CoordOff|Connected|Dot|Sequential|Simul|RectGC|PolarGC|ExprOn|ExprOff|Full|Horiz|ZStandard|ZSquare|ZDecimal|ZInteger|ZBox|ZTrig|ZoomFit|ZoomStat|ZPrevious|ZoomIn|ZoomOut|PlotsOn|PlotsOff|FnOn|FnOff)\\b"
    },
    "keyword-math": {
      "name": "support.function.math.ti84p",
      "match": "\\b(abs|round|iPart|fPart|int|min|max|lcm|gcd|remainder|sqrt|cubert|ln|log|logBASE|sin|cos|tan|asin|acos|atan|sinh|cosh|tanh|nDeriv|fnInt|solve|fMin|fMax|rand|randInt|randNorm|randBin|randIntNoRep|randM|nPr|nCr|seq|sum|prod|mean|median|stdDev|variance|dim|Fill|augment|cumSum|dList|sortA|sortD|det|identity|rref|ref|rowSwap|conj|real|imag|angle|List>matr|Matr>list|expr|sub|inString|length|Select|SinReg|LinReg|QuadReg|CubicReg|QuartReg|LnReg|ExpReg|PwrReg|Logistic|1-Var Stats|2-Var Stats|SetUpEditor|GarbageCollect)\\b"
    },
    "keyword-memory": {
      "name": "keyword.other.memory.ti84p",
      "match": "\\b(Archive|UnArchive|DelVar|GarbageCollect|ClrList|ClrAllLists|ClrTable)\\b"
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.store.ti84p",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.ti84p",
          "match": "(!=|<=|>=|[=<>])"
        },
        {
          "name": "keyword.operator.logical.ti84p",
          "match": "\\b(and|or|xor|not)\\b"
        },
        {
          "name": "keyword.operator.arithmetic.ti84p",
          "match": "[+\\-*\\/\\^!]"
        },
        {
          "name": "keyword.operator.conversion.ti84p",
          "match": ">(Frac|Dec|DMS|Polar|Rect)"
        }
      ]
    },
    "builtin-list": {
      "name": "variable.other.list.ti84p",
      "match": "\\bL[1-6]\\b|\\bL\\.[A-Z][A-Z0-9]{0,4}\\b"
    },
    "builtin-matrix": {
      "name": "variable.other.matrix.ti84p",
      "match": "\\[[A-J]\\]"
    },
    "builtin-string": {
      "name": "variable.other.string-var.ti84p",
      "match": "\\bStr[0-9]\\b"
    },
    "number": {
      "name": "constant.numeric.ti84p",
      "match": "\\b[0-9]+(\\.[0-9]+)?(E[+-]?[0-9]+)?\\b"
    },
    "variable": {
      "name": "variable.other.ti84p",
      "match": "\\b(pi|e|i|theta|Ans|[A-Z])\\b"
    }
  }
}
