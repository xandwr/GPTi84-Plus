{
  "name": "vscode-ti84p",
  "displayName": "TI-84 Plus TI-BASIC",
  "description": "Syntax highlighting, autocomplete, and diagnostics for TI-BASIC (.ti84p) targeting the TI-84 Plus / 84+SE.",
  "version": "0.1.0",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ti84p",
        "aliases": ["TI-84 Plus BASIC", "ti84p"],
        "extensions": [".ti84p"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ti84p",
        "scopeName": "source.ti84p",
        "path": "./syntaxes/ti84p.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
