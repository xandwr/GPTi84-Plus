    1 00:0000 -  -  -  -  ; hello.asm: minimal "HELLO WORLD" assembly program for the TI-84 Plus.
    2 00:0000 -  -  -  -  ; Assembled with spasm-ng, produces an .8Xp that runs via Asm(prgmHELLO).
    3 00:0000 -  -  -  -  ;
    4 00:0000 -  -  -  -  ; No TI SDK headers required: bcall vectors and constants are spelled out
    5 00:0000 -  -  -  -  ; here so this file builds against a stock spasm-ng install.
    6 00:0000 -  -  -  -  
    7 00:0000 -  -  -  -  #define bcall(x) rst 28h \ .dw x
    8 00:0000 -  -  -  -  
    9 00:0000 -  -  -  -  _HomeUp   .equ 4558h
   10 00:0000 -  -  -  -  _PutS     .equ 450Ah
   11 00:0000 -  -  -  -  _NewLine  .equ 452Eh
   12 00:0000 -  -  -  -  _GetKey   .equ 4972h
   13 00:0000 -  -  -  -  
   14 00:0000 -  -  -  -  ; .8Xp programs load at $9D93 with a two-byte AsmPrgm marker.
   15 00:0000 -  -  -  -  .org    9D93h
   16 00:9D93 BB 6D -  -  .db     0BBh, 6Dh
   17 00:9D95 -  -  -  -  
   18 00:9D95 EF 58 45 -      bcall(_HomeUp)
