   21 00:9D9E EF 2E 45 -      bcall(_NewLine)
   22 00:9DA1 EF 72 49 -      bcall(_GetKey)
   23 00:9DA4 C9 -  -  -      ret
   24 00:9DA5 -  -  -  -  
