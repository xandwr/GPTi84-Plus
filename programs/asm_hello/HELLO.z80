; HELLO.z80: minimal AsmPrgm for TI-83+/84+. Clears the home screen,
; writes a string, waits for any key, returns to the OS.
;
; Build:
;   spasm -I references/spasm programs/asm_hello/HELLO.z80 programs/asm_hello/HELLO.8xp
;
; spasm-ng emits a complete .8Xp file (header + entry + checksum) and uses
; the AsmPrgm token (BB 6D) automatically when the source begins with the
; .org $9D93 / .db t2ByteTok, tAsmCmp pattern below.

.nolist
#include "ti83plus.inc"
.list

.org    $9D93
.db     t2ByteTok, tAsmCmp     ; AsmPrgm header (BB 6D)

        bcall(_ClrLCDFull)
        ld      hl, 0           ; row=0, col=0
        ld      (curRow), hl
        ld      hl, msg
        bcall(_PutS)
        bcall(_GetKey)
        bcall(_ClrLCDFull)
        ret

msg:    .db     "HELLO FROM ASM", 0

.end
