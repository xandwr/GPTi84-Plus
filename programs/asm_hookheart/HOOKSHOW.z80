; HOOKSHOW.z80: read the counter byte that HOOKINST's hook increments
; and print it as a decimal number. If the count rises between runs
; (with key activity in between), the hook is alive.
;
; Build:  just asm  programs/asm_hookheart/HOOKSHOW.z80
; Push:   just push-asm programs/asm_hookheart/HOOKSHOW.z80

.nolist
#include "ti83plus.inc"
.list

.org    $9D93
.db     t2ByteTok, tAsmCmp

COUNTER_ADDR    .equ    saveSScreen + $20       ; must match HOOKINST

        bcall(_ClrLCDFull)
        ld      hl, 0
        ld      (curRow), hl
        ld      hl, label
        bcall(_PutS)

        ld      a, (COUNTER_ADDR)
        ld      l, a
        ld      h, 0
        bcall(_DispHL)                  ; HL printed as decimal
        ret

label:  .db     "count=", 0

.end
